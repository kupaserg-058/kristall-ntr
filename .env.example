# Gemini API key — получить бесплатно на https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Подключение к PostgreSQL (обязательно драйвер asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/kristall

# Разрешённые origin'ы для CORS (через запятую). В dev достаточно дефолта.
CORS_ORIGINS=http://localhost:5173
